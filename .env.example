# Copy this file to .env and fill in your values.
# Never commit .env — it is gitignored.

DATABASE_URL="file:./dev.db"

# Twilio — required for sending landlord verification links via SMS
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Entrata — required for application import and auto-sync
ENTRATA_BASE_URL=https://your-property.entrata.com
ENTRATA_USERNAME=
ENTRATA_PASSWORD=

# Resend — required for landlord verification emails and staff notifications
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=VerifyRent <noreply@yourdomain.com>
NOTIFY_EMAIL=staff@yourdomain.com

# Google OAuth — required for staff login (create at console.cloud.google.com)
# Generate AUTH_SECRET with: npx auth secret
AUTH_SECRET=
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Cron secret — required in production to protect /api/entrata/sync
# Generate with: openssl rand -hex 32
CRON_SECRET=

# Dev only — set to true in .env.local (never here) to bypass Google OAuth in development
DEV_AUTH_BYPASS=false
